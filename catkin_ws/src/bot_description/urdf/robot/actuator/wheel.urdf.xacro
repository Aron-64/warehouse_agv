<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <xacro:include filename="$(find bot_description)/urdf/robot/common_inertia.urdf.xacro"/>

    <xacro:macro name="wheel_xacro" params="wheel_name xyz">
        <!-- 机器人轮子部件 -->
        <link name="${wheel_name}_link">
            <!-- 轮子的视觉描述 -->
            <visual>
                <!-- 轮子的几何中心偏移和旋转量 -->
                <origin xyz="0 0 0" rpy="1.57079 0 0"/>
                <geometry>
                    <!-- 圆柱体半径0.032m，高度0.04m -->
                    <cylinder radius="0.032" length="0.04"/>
                </geometry>
                <material name="yellow">
                    <color rgba="1 1 0 0.8"/>
                </material>
            </visual>
            <collision>
                <!-- 轮子的几何中心偏移和旋转量 -->
                <origin xyz="0 0 0" rpy="1.57079 0 0"/>
                <geometry>
                    <!-- 圆柱体半径0.032m，高度0.04m -->
                    <cylinder radius="0.032" length="0.04"/>
                </geometry>
                <material name="yellow">
                    <color rgba="1 1 0 0.8"/>
                </material>
            </collision>
            <xacro:cylinder_inertia m="0.2" r="0.032" h="0.04"/>
        </link>

        <!-- 连接机器人主体和轮子 -->
        <joint name="${wheel_name}_joint" type="continuous">
            <parent link="base_link"/>
            <child link="${wheel_name}_link"/>
            <origin xyz="${xyz}" rpy="0 0 0"/>
            <axis xyz="0.0 1.0 0.0"/>
        </joint>

        <gazebo reference="${wheel_name}_link">
            <!-- 切向摩擦系数 -->
            <mu1 value="20.0"/>
            <!-- 法向摩擦系数 -->
            <mu2 value="20.0"/>
            <!-- 接触的刚度系数 -->
            <kp value="10000000000.0"/>
            <!-- 接触的阻尼系数 -->
            <kd value="1.0"/>
            <material>Gazebo/Yellow</material>
        </gazebo>
    </xacro:macro>
</robot>
